# Caddy reverse proxy para el stack DevLake en produccion (DigitalOcean Droplet).
#
# Arquitectura de hostnames:
#   - {$DOMAIN}        (ej: devlake.greencodesoftware.com) -> Grafana, login Google OAuth
#   - api.{$DOMAIN}    (ej: api.devlake.greencodesoftware.com) -> DevLake REST API
#                       /api/plugins/webhook/*  publico (Sentry, dora-deploy)
#                       /api/*                  basic auth (admin endpoints)
#
# La separacion en subdominios es obligatoria porque Grafana y DevLake comparten
# el namespace /api/ (Grafana usa /api/user, /api/plugins, etc.; DevLake usa
# /api/projects, /api/plugins, etc.). Path-based routing no alcanza para
# distinguirlos.
#
# Activacion:
#   docker compose -f docker/docker-compose.yml -f docker/caddy/docker-compose.caddy.yml up -d
#
# DNS requerido en Route 53 (ambos -> Reserved IP del droplet):
#   devlake.greencodesoftware.com      A  <IP>
#   api.devlake.greencodesoftware.com  A  <IP>
#
# Variables tomadas de .env (decryptado por SOPS al boot):
#   DOMAIN, ACME_EMAIL, BASIC_AUTH_USER, BASIC_AUTH_HASH

{
    email {$ACME_EMAIL}
    # Descomentar si Cloudflare delante (modo "Full strict"). CF emite cert al edge,
    # Caddy emite cert al origin. No mezclar con tunnel-only mode.
    # acme_dns cloudflare {env.CF_API_TOKEN}
}

# ============================================================
# SITE 1: Grafana (Google OAuth)
# ============================================================
{$DOMAIN} {
    encode zstd gzip

    log {
        output file /var/log/caddy/access.log {
            roll_size 50mb
            roll_keep 7
        }
        format json
    }

    # Todo va a Grafana. Su /api/ es para uso propio (user, org, dashboards, plugins
    # de Grafana, etc.) y el auth lo maneja Grafana via Google OAuth.
    reverse_proxy grafana:3000

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "no-referrer-when-downgrade"
    }
}

# ============================================================
# SITE 2: DevLake REST API (basic auth, salvo webhooks)
# ============================================================
api.{$DOMAIN} {
    encode zstd gzip

    log {
        output file /var/log/caddy/access-api.log {
            roll_size 50mb
            roll_keep 7
        }
        format json
    }

    # El backend DevLake sirve la API en ROOT, no bajo /api (verificado 2026-07-02
    # contra el container: GET devlake:8080/projects -> 200 ; /api/projects -> 404).
    # Hay que strippear el prefijo /api antes de proxyear.
    #
    # Se usa un bloque `route` (orden de directivas EXPLICITO, sin el reordenamiento
    # canonico de Caddy) y el strip se hace a nivel de route, NO dentro de un handle.
    # Motivo (verificado 2026-07-03 via `caddy adapt`): si el rewrite del strip
    # comparte subroute con un handler `authentication`, Caddy lo DROPEA — el route
    # admin quedaba [authentication, reverse_proxy] SIN el strip, y /api/projects
    # llegaba al backend como /api/projects -> 404. (Pasa con basic_auth dentro o
    # afuera del handle, y con handle_path.) Con el strip afuera del auth, sobrevive.
    route {
        # 1) fuera de /api -> 404 informativo (sobre el path ORIGINAL, antes del strip)
        @notapi not path /api/*
        respond @notapi "DevLake API. Endpoints under /api/." 404

        # 2) el backend sirve en root -> quitamos /api para todos los endpoints
        uri strip_prefix /api

        # 3) webhook publico (ya sin /api): SIN auth. Sentry y dora-deploy postean aca.
        #    Proteccion: connection-id secreto-por-oscuridad + HMAC opcional en Sentry.
        handle /plugins/webhook/* {
            reverse_proxy devlake:8080 {
                header_up Host {host}
                header_up X-Real-IP {remote_host}
            }
        }

        # 4) resto de la API DevLake: basic auth + proxy a root
        @admin not path /plugins/webhook/*
        basic_auth @admin {
            {$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
        }
        reverse_proxy devlake:8080
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "no-referrer-when-downgrade"
    }
}

# redirect HTTP → HTTPS lo hace Caddy implicitamente cuando hay un site bloque sin :80
