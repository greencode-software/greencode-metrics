# Template de secrets para el stack DevLake en DigitalOcean Droplet.
#
# NUNCA commitear este archivo con valores reales. La version productiva vive
# encriptada en secrets/prod.env.sops (mismo formato, ofuscada por SOPS+age).
#
# Flujo en droplet:
#   1) scripts/bootstrap-droplet.sh descifra secrets/prod.env.sops con `sops -d`
#      usando la age private key en /etc/sops/age/keys.txt.
#   2) Lo escribe a /opt/devlake/docker/.env.
#   3) docker compose levanta el stack consumiendo ese .env.
#
# Generacion de valores nuevos (en la maquina del admin que hace el bootstrap):
#   openssl rand -hex 32     # para ENCRYPTION_SECRET (32 bytes = 256 bits)
#   openssl rand -base64 24  # para passwords
#   docker run --rm caddy:2.8-alpine caddy hash-password --plaintext '<pass>'
#                            # para BASIC_AUTH_HASH (bcrypt)

# ---------- DB ----------
MYSQL_ROOT_PASSWORD=REPLACE_ME_strong_random_pass
MYSQL_PASSWORD=REPLACE_ME_strong_random_pass

# ---------- Grafana ----------
# Solo se usa para el primer login. Despues va Google OAuth — ver runbook.
GRAFANA_ADMIN_PASSWORD=REPLACE_ME_strong_random_pass

# ---------- DevLake encryption ----------
# Encripta TODOS los tokens guardados en MySQL (GitHub PATs, Sentry tokens, etc.).
# CRITICO: perderla = imposible recuperar los tokens.
# Guardar copia tambien en 1Password (vault del lider tecnico).
ENCRYPTION_SECRET=REPLACE_ME_hex_32_bytes

# ---------- Caddy (reverse proxy) ----------
DOMAIN=devlake.greencodesoftware.com
ACME_EMAIL=plataforma@greencodesoftware.com

# Basic auth para /admin y /api/* (excepto webhooks). Hash bcrypt; generar con:
#   docker run --rm caddy:2.8-alpine caddy hash-password --plaintext '<pass>'
BASIC_AUTH_USER=greencode
BASIC_AUTH_HASH='$2a$14$REPLACE_ME_bcrypt_hash_de_la_password'

# ---------- Google OAuth para Grafana ----------
# Crear cliente OAuth 2.0 en console.cloud.google.com:
#   Authorized redirect URI: https://devlake.greencodesoftware.com/login/google
# Restringir a dominio @greencodesoftware.com via GF_AUTH_GOOGLE_ALLOWED_DOMAINS.
GF_AUTH_GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com
GF_AUTH_GOOGLE_CLIENT_SECRET=REPLACE_ME
GF_AUTH_GOOGLE_ALLOWED_DOMAINS=greencodesoftware.com

# ---------- Backups: DO Spaces ----------
# API → Spaces Keys en la consola de DigitalOcean.
DO_SPACES_KEY=REPLACE_ME_DO_spaces_access_key
DO_SPACES_SECRET=REPLACE_ME_DO_spaces_secret
DO_SPACES_BUCKET=greencode-devlake-backups
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# ---------- Tokens de plataformas (van adentro de connections DevLake) ----------
# Estos NO son leidos por el compose en si. Quedan en el .env asi el script de
# onboarding los toma como env vars y los manda a DevLake via API.
# DevLake los encripta con ENCRYPTION_SECRET y los guarda en MySQL.
#
# Hoy: una sola cuenta (elamonica) tiene acceso a todos los repos (personal + org).
# Cuando se cree un usuario de servicio, agregar GH_TOKEN_GREENCODE_BOT aca.
GH_TOKEN_ELAMONICA=REPLACE_ME_classic_pat_with_scopes_repo_read_org_read_user_workflow

# Sentry — API token para polling de incidents y release health
SENTRY_AUTH_TOKEN=REPLACE_ME_sentry_auth_token

# Para Bitbucket cuando aplique:
# BB_USERNAME_GREENCODE=
# BB_APP_PASS_GREENCODE=
